menu "Configuracion de la aplicación"

    config APP_HEARTBEAT_PERIOD_MS
        int "LED heartbeat period (100-2000)"
        range 100 2000
        default 500

    menuconfig LED_SUBSYSTEM
        bool "LED Subsystem"
        default y

    if LED_SUBSYSTEM
        choice
            prompt "LED blink sleep time"
            default BLINK_SLEEP_TIME_1000_MS

            config BLINK_SLEEP_TIME_250_MS
                bool "250 ms (very fast)"

            config BLINK_SLEEP_TIME_500_MS
                bool "500 ms (fast)"

            config BLINK_SLEEP_TIME_1000_MS
                bool "1s (medium)"
            
            config BLINK_SLEEP_TIME_2000_MS
                bool "2s (slow)"
        endchoice

        config LED_BLINK_SLEEP_TIME
            int
            default 250 if BLINK_SLEEP_TIME_250_MS
            default 500 if BLINK_SLEEP_TIME_500_MS
            default 1000 if BLINK_SLEEP_TIME_1000_MS
            default 2000 if BLINK_SLEEP_TIME_2000_MS
        
        menuconfig ADVANCED_LED_SETTINGS
            bool "Advanced LED settings"
            default n

        if ADVANCED_LED_SETTINGS
            config LED_BRIGHTNESS
                int "LED brightness (0-100)"
                range 0 100
                default 100

            config LED_FADE_DURATION
                int "LED fade duration (ms)"
                range 0 5000
                default 500

            config LED_EXPERT_SETTINGS
                bool
                default y

            menu "Expert settings"
                visible if LED_EXPERT_SETTINGS

                config LED_DEBUG
                    bool "Enable LED debugging"
                    default n

                config LED_CUSTOM_BLINK_PATTERN
                    bool "Custom blink pattern"
                    default n
            endmenu #Expert settings
        endif #ADVANCED_LED_SETTINGS
    endif #LED_SUBSYSTEM
endmenu #Configuracion de la aplicación


menu "Configuracion de Zephyr"
    source "Kconfig.zephyr"
endmenu